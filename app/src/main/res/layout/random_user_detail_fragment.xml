<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentation.ui.randomuserlist.RandomUserListFragment"
    android:background="@color/white">

    <ImageView
        android:id="@+id/iv_random_user_image_details"
        android:layout_marginLeft="24dp"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tv_random_user_name_details"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceListItem"
        android:text="Name"
        android:layout_marginLeft="24dp"
        app:layout_constraintTop_toTopOf="@id/iv_random_user_image_details"
        app:layout_constraintStart_toEndOf="@id/iv_random_user_image_details"
        />
    <TextView
        android:id="@+id/tv_random_user_email_details"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceListItem"
        android:text="Email"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="@id/tv_random_user_name_details"
        app:layout_constraintStart_toStartOf="@id/tv_random_user_name_details"/>
    <TextView
        android:id="@+id/tv_random_user_phone_details"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceListItem"
        android:text="Phone"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="@id/tv_random_user_email_details"
        app:layout_constraintStart_toStartOf="@id/tv_random_user_name_details"/>
    <TextView
        android:id="@+id/tv_random_user_gender_details"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceListItem"
        android:text="Gender"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="@id/tv_random_user_phone_details"
        app:layout_constraintStart_toStartOf="@id/tv_random_user_name_details"/>
    <TextView
        android:id="@+id/tv_random_user_location_details"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceListItem"
        android:text="Location"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="@id/tv_random_user_gender_details"
        app:layout_constraintStart_toStartOf="@id/tv_random_user_name_details"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/tv_random_user_registered_details"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceListItem"
        android:text="Registered Date"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="@id/tv_random_user_location_details"
        app:layout_constraintStart_toStartOf="@id/tv_random_user_name_details"/>

</androidx.constraintlayout.widget.ConstraintLayout>